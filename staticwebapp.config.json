{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"],
      "headers": { "Cache-Control": "private, no-store" }
    },
    {
      "route": "/admin/*",
      "headers": { "Cache-Control": "private, no-store" }
    },
    {
      "route": "/login",
      "headers": { "Cache-Control": "private, no-store" }
    },

    {
      "route": "/sitemap.xml",
      "headers": { "Cache-Control": "public, s-maxage=3600, stale-while-revalidate=86400" }
    },
    {
      "route": "/feed.xml",
      "headers": { "Cache-Control": "public, s-maxage=3600, stale-while-revalidate=86400" }
    },

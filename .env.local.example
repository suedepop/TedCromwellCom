# Setlist.fm
SETLISTFM_API_KEY=
SETLISTFM_USERNAME=

# Cosmos DB
COSMOS_ENDPOINT=https://tedcromwell-cosmos.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=tedcromwell

# Azure Blob Storage
BLOB_CONNECTION_STRING=
BLOB_ACCOUNT_NAME=tedcromwellstore

# Auth
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
JWT_SECRET=

# App
NEXT_PUBLIC_BASE_URL=https://www.tedcromwell.com

# Google Analytics (GA4 measurement ID, e.g. G-XXXXXXXXXX) — leave blank to disable
NEXT_PUBLIC_GA_ID=

# Facebook Page posting (server-side only; never NEXT_PUBLIC_*)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Discogs collection import (server-side only)
DISCOGS_USERNAME=
DISCOGS_KEY=
DISCOGS_SECRET=

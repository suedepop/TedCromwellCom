    },
    {
      "route": "/opensearch.xml",
      "headers": { "Cache-Control": "public, s-maxage=86400, stale-while-revalidate=604800" }
    },
    {
      "route": "/robots.txt",
      "headers": { "Cache-Control": "public, s-maxage=86400, stale-while-revalidate=604800" }
    },

    {
      "route": "/blog/*",
      "headers": { "Cache-Control": "public, s-maxage=3600, stale-while-revalidate=86400" }

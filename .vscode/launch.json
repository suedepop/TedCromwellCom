{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Next.js: client-side (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Next.js: client-side (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Verify Azure connections",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "verify"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Next.js: full stack (Edge)",
      "configurations": ["Next.js: server-side", "Next.js: client-side (Edge)"],
      "stopAll": true
    },
    {
      "name": "Next.js: full stack (Chrome)",
      "configurations": ["Next.js: server-side", "Next.js: client-side (Chrome)"],
      "stopAll": true
    }
  ]
}
